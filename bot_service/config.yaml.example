# PE Knowledge Base Bot Configuration
# Copy to config.yaml and fill in the values

feishu:
  appId: "cli_xxxxxxxxxxxxxxxx"  # Your Feishu App ID
  appSecret: "xxxxxxxxxxxxxxxx"  # Your Feishu App Secret
  botName: "pe-kb-bot"

ragService:
  baseUrl: "http://localhost:8080"  # RAG service URL
  timeout: 60000  # 60 seconds

redis:
  url: "redis://localhost:6379/0"
  sessionTtl: 3600  # 1 hour
  eventDedupeTtl: 600  # 10 minutes
