# Feishu Bot Configuration
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Push target - the open_id of the user to receive daily reports
SCHEDULER_TARGET_OPEN_ID=ou_xxxxxxxxxxxxxxxx

# Schedule time (24-hour format, default 15:30 = 收盘后)
SCHEDULER_HOUR=15
SCHEDULER_MINUTE=30

# Feishu Bitable (产品表-同步)
# 多维表格的 App Token（可以从表格 URL 中获取，格式如 bascnxxxxxx）
BITABLE_APP_ID=
# 多维表格内具体数据表的 ID（格式如 tblxxxxxx）
BITABLE_TABLE_ID=

# Market indices to track (comma-separated)
# 支持: 上证指数,深证成指,创业板指,科创50,沪深300,上证50,中证500,中证1000
MARKET_INDICES=上证指数,创业板指,科创50,沪深300

# 敲出点位每月递减比例（%，来自参考表格）
MONTHLY_DECREMENT=0.5
