# 飞书配置 (Step 2 必须)
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_DOC_ID=doccnxxxxxxxxxxxxxxxx

# 通义千问 API (Step 2 必须)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 数据库 (Step 4 需要，Step 2 可不填)
# POSTGRES_DSN=postgresql://user:password@localhost:5432/pekb

# 向量库 (Step 4 需要，Step 2 可不填)
# QDRANT_URL=http://localhost:6333
# QDRANT_COLLECTION=pe_kb_chunks

# Redis (Step 4 需要，Step 2 可不填)
# REDIS_URL=redis://localhost:6379/0

# 定时调度配置 (Step 9+ 定时推送)
# SCHEDULER_TARGET_OPEN_ID=ou_xxxxxxxxxxxxxxxx  # 推送目标的飞书 open_id
# SCHEDULER_HOUR=15  # 推送小时（24小时制），默认 15
# SCHEDULER_MINUTE=30  # 推送分钟，默认 30
